# 后端 API 基础地址（可选）
# 例如：VITE_API_BASE=http://192.168.2.94:18080
# 不配置时，前端会使用当前页面主机的 18080 端口。
VITE_API_BASE=

# mediamtx 转发服务配置（按你的 CameraXX 规则）
# 示例：
# VITE_MEDIA_HOST=192.168.2.94
# VITE_MEDIA_RTSP_PORT=8554
# VITE_MEDIA_WEBRTC_PORT=8889
VITE_MEDIA_HOST=
VITE_MEDIA_RTSP_PORT=
VITE_MEDIA_WEBRTC_PORT=

